# templates/snort.rules.j2
alert icmp any any -> any any (msg:"ICMP Ping Detected"; sid:1000002; rev:1;)
alert tcp any any -> any any (msg:"IDS Detection Test"; content:"attack-test"; sid:1000001; rev:1;)

  # [1] IP 스푸핑 (외부에서 내부 IP로 들어오는 패킷)
  alert ip 172.31.0.0/16 any -> 172.31.0.0/16 any (msg:"IP Spoofing Alert"; sid:1000011; rev:2;)

  # [2] SYN Flood (DDoS)  (5초 내에 SYN 패킷 20개 이상)
  alert tcp any any -> any any (msg:"SYN Flood Attack Detected"; flags:S; threshold:type threshold, track by_dst, count 20, seconds 5; sid:1000012; rev:1;)

  # [3] Xmas Scan (공격용 비정상 플래그 조합)
  alert tcp any any -> any any (msg:"TCP Xmas Scan Attempt"; flags:FPU; sid:1000013; rev:1;)

  # [4] NULL Scan (플래그가 없는 패킷)
  alert tcp any any -> any any (msg:"TCP NULL Scan Attempt"; flags:0; sid:1000014; rev:1;)

  # [5] Brute Force (무차별 대입 공격 30초 5번)
  alert tcp any any -> any 22 (msg:"SSH Brute Force Attempt"; flags:S; threshold:type both, track by_src, count 5, seconds 30; sid:1000015; rev:1;)

  # [6] Directory Traversal
  alert tcp any any -> any 80 (msg:"Web Directory Traversal Attempt"; content:"../"; nocase; sid:1000016; rev:1;)
  alert tcp any any -> any 80 (msg:"Access to Sensitive File (/etc/passwd)"; content:"/etc/passwd"; nocase; sid:1000017; rev:1;)

  # [7] Sensitive File Access
  alert tcp any any -> any 80 (msg:"Access to /etc/passwd Attempt"; content:"etc/passwd"; nocase; sid:1000018; rev:1;)

  # [8] Reverse Shell 및 원격 실행 탐지
  alert tcp any any -> any any (msg:"Possible Reverse Shell Activity"; content:"/bin/sh"; nocase; sid:1000019; rev:1;)
  alert ip any any -> any any (msg:"Possible Windows Remote Shell"; content:"cmd.exe"; nocase; sid:1000020; rev:1;)

  # [9] SQL Injection (기본 패턴) 탐지
  alert tcp any any -> any 80 (msg:"SQL Injection Attempt: OR 1=1"; content:"or 1=1"; nocase; sid:1000021; rev:1;)
  alert tcp any any -> any 80 (msg:"SQL Injection Attempt: UNION SELECT"; content:"union select"; nocase; sid:1000022; rev:1;)

  # [10] 비정상 ICMP
  alert icmp any any -> any any (msg:"Suspicious Large ICMP Packet"; dsize:>100; itype:8; sid:1000023; rev:1;)

  # [11] port scanning (1분에 10개 이상 포트 접속)
  alert tcp any any -> any any (msg:"Potential Port Scanning Detected"; flags:S; threshold:type both, track by_src, count 10, seconds 60; sid:1000024; rev:1;)

  # [12] data leakage 
  alert tcp any any -> any 80 (msg:"Data Exfiltration Attempt: SELECT ALL"; content:"select * from"; nocase; sid:1000025; rev:1;)

  # [13] buffer overflow
  alert ip any any -> any any (msg:"Possible Buffer Overflow: NOP Sled Detected"; content:"|90 90 90 90 90 90 90 90|"; sid:1000027; rev:1;)

  # [14] 관리자 페이지 접근 시도
  # 환경 설정 파일(.env)에 접근하려는 시도 (자격 증명 탈취 목적)
  alert tcp any any -> any 80 (msg:"Access to Configuration File (.env)"; content:".env"; nocase; sid:1000028; rev:1;)
  # 관리자 로그인 페이지 무차별 접근
  alert tcp any any -> any 80 (msg:"Admin Page Access Attempt"; content:"/admin"; nocase; sid:1000029; rev:1;)

{% if custom_rules is defined %}
{{ custom_rules }}
{% endif %}
