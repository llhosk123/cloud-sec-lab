# =================================================================
# [Level 1: Critical] - 시스템 권한 탈취 및 침투 (즉시 차단 권장)
# =================================================================
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"IDS: Critical [DROP] - Reverse Shell Pattern (/bin/sh)"; content:"/bin/sh"; nocase; priority:1; sid:1000111; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"IDS: Critical [DROP] - Reverse Shell Pattern (/bin/bash)"; content:"/bin/bash -i"; nocase; priority:1; sid:1000112; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"IDS: Critical [DROP] - Malicious Script Socket Attempt"; content:"python -c"; content:"import socket"; nocase; priority:1; sid:1000113; rev:1;)
alert tcp any any -> $HOME_NET any (msg:"IDS: Critical [DROP] - Log4j JNDI Lookup Detected"; content:"jndi:ldap://"; nocase; priority:1; sid:1000114; rev:1;)

# =================================================================
# [Level 2: High] - 내부 정찰 및 공격 도구 사용 (실시간 차단)
# =================================================================
alert tcp $HOME_NET any -> $HOME_NET any (msg:"IDS: High [DROP] - Internal Network Scanning Detected"; content:"nmap "; nocase; priority:2; sid:2000111; rev:1;)
alert tcp $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (msg:"IDS: High [DROP] - Malicious Payload Download (.sh)"; content:".sh"; http_uri; priority:2; sid:2000112; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"IDS: High [DROP] - TCP Flood Attack Detected"; flags:S; threshold:type both, track by_src, count 20, seconds 1; priority:2; sid:2000113; rev:1;)
alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"IDS: High [DROP] - ICMP Flood Attack Detected"; threshold:type both, track by_src, count 50, seconds 1; priority:2; sid:2000114; rev:1;)

# =================================================================
# [Level 3: Medium] - 민감 설정 파일 및 계정 정보 접근 (사전 차단)
# =================================================================
alert tcp any any -> any 22 (msg:"IDS: Medium - Sensitive File Access (/etc/passwd)"; content:"cat /etc/passwd"; nocase; priority:3; sid:3000111; rev:2;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"IDS: Medium - Sensitive File Access (/etc/shadow)"; content:"cat /etc/shadow"; nocase; priority:3; sid:3000112; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"IDS: Medium - Private Key Theft Attempt"; content:".ssh/id_rsa"; nocase; priority:3; sid:3000113; rev:1;)

# =================================================================
# [Level 4: Low] - 공격 전조 징후 (추적 및 로그 기록)
# =================================================================
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"IDS: Low - SSH Brute Force Attempt"; flags:S; threshold:type both, track by_src, count 5, seconds 30; priority:4; sid:4000112; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"IDS: Low - Potential Port Scanning"; flags:S; threshold:type both, track by_src, count 10, seconds 60; priority:4; sid:4000113; rev:1;)

# =================================================================
# [Level 5: Info] - 단순 네트워크 확인 (기록 및 가용성 체크)
# =================================================================
alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"IDS: Info - ICMP Ping Detected"; itype:8; priority:5; sid:5000111; rev:1;)